  METHOD create_inb_deliveries.
    DATA : lv_lfdat   TYPE lfdat_v,
           lv_lddat   TYPE lfdat,
           lv_zzvesel TYPE zvesel.
"*{ Begin of V02
    DATA:  lv_zcndoc   TYPE zcndoc.
"*} End of V02
    CLEAR : i_komdlgn,
            wa_vbsk,
            i_vbfs,
            i_vbls,
            i_lips2,
            lv_lfdat,
            lv_lddat,
"*{ Begin of V02
            lv_zcndoc,
"*} End of V02
            lv_zzvesel.
    LOOP AT i_coildata
      ASSIGNING <fs_coildata>
      WHERE ebeln = fp_ebeln
        AND ebelp = fp_ebelp
        AND zzvesel = fp_zzvesel
        AND err = 'X'.
      CONCATENATE 'PO' <fs_coildata>-ebeln  'Error : ' <fs_coildata>-msg
        INTO wa_msg SEPARATED BY space.
    ENDLOOP.

    CALL FUNCTION 'MESSAGES_INITIALIZE'.

    LOOP AT i_coildata
      ASSIGNING <fs_coildata>
      WHERE ebeln = fp_ebeln
        AND ebelp = fp_ebelp
        AND zzvesel = fp_zzvesel
*        AND err = space.
        AND errpo = space.  "Check if entire PO is in error.
      MOVE <fs_coildata>-lfdat      TO lv_lfdat.
      MOVE <fs_coildata>-lddat      TO lv_lddat.
      MOVE <fs_coildata>-zzvesel    TO lv_zzvesel.
"*{ Begin of V02
      MOVE <fs_coildata>-zzcndoc    TO lv_zcndoc.
"*} End of V02
      SELECT SINGLE *
        INTO wa_ekpo
        FROM ekpo
       WHERE ebeln EQ <fs_coildata>-ebeln
         AND ebelp EQ <fs_coildata>-ebelp.

      wa_komdlgn-lfdat = <fs_coildata>-lfdat.
      wa_komdlgn-matnr = wa_ekpo-matnr.
      wa_komdlgn-lfimg = <fs_coildata>-lfimg.
      wa_komdlgn-lichn = <fs_coildata>-lichn.
      wa_komdlgn-vrkme = <fs_coildata>-vrkme.
      wa_komdlgn-vgbel = <fs_coildata>-ebeln.
      wa_komdlgn-vgpos = <fs_coildata>-ebelp.
      READ TABLE i_delvsumm
        ASSIGNING <fs_delvsumm>
        with KEY ebeln = <fs_coildata>-ebeln
                 ebelp = <fs_coildata>-ebelp
                zzvesel = <fs_coildata>-zzvesel.
      IF sy-subrc = 0.
        wa_komdlgn-anzpk = <fs_delvsumm>-no_of_coils.
      ENDIF.

* set default parameter
      wa_komdlgn-vgtyp = 'V'.
      wa_komdlgn-kzazu = c_x.
      wa_komdlgn-lfart = 'EL'.
      APPEND wa_komdlgn TO i_komdlgn.
    ENDLOOP.

    DATA lt_prop TYPE STANDARD TABLE OF wuebs.
*  ** Code from IDOC_INPUT_DESADV1
*  ** Not Available in 3.1
    CALL FUNCTION 'ME_CONFIRMATION_VIA_EDI'
         TABLES
              t_kom  = i_komdlgn
              errors = lt_prop
         EXCEPTIONS
              OTHERS = 1.

    IF sy-subrc NE 0.
      WRITE / 'Error Coccured in ME_CONFIRMATION_VIA_EDI'(054).
    ENDIF.
***** Create
    DATA: nrnr TYPE nrnr.
* Sammelgangsnummer vergeben
    wa_vbsk-mandt = sy-mandt.
    wa_vbsk-ernam = sy-uname.
"*{ Begin of V01  -
*    wa_vbsk-erdat = sy-datum.
    wa_vbsk-erdat = sy-datlo.
    wa_vbsk-uzeit = sy-timlo.
*    wa_vbsk-uzeit = sy-uzeit.
"*} End of V01  -
    wa_vbsk-smart = 'L'.
    DATA: wa_tvsa TYPE tvsa.
    SELECT SINGLE *
      FROM tvsa
      INTO wa_tvsa
      WHERE smart = wa_vbsk-smart.
    IF sy-subrc <> 0.
*** Error Handling To be Done
*   Meldung ins Protokoll
    ENDIF.

    nrnr = wa_tvsa-numki.
    CALL FUNCTION 'NUMBER_GET_NEXT'
         EXPORTING
              nr_range_nr = nrnr
              object      = 'RV_SAMMG'
         IMPORTING
              number      = wa_vbsk-sammg
         EXCEPTIONS
              OTHERS      = 1.
    IF sy-subrc <> 0.
*** Error Hadling TBD
*   Meldung ins Protokoll
    ENDIF.

**** Call Core Function GN_DELIVERY_CREATE.
    CALL FUNCTION 'GN_DELIVERY_CREATE'
         EXPORTING
              vbsk_i   = wa_vbsk
         IMPORTING
              vbsk_e   = wa_vbsk
         TABLES
              xkomdlgn = i_komdlgn
              xvbfs    = i_vbfs
              xvbls    = i_vbls
              xxlips   = i_lips2
         EXCEPTIONS
              OTHERS   = 1.
    IF sy-subrc EQ 0.
      READ TABLE i_lips2
        ASSIGNING <fs_lips2>
        INDEX 1.
      IF sy-subrc EQ 0
      AND <fs_lips2>-vbeln IS NOT INITIAL.
"As soon as delivery is created update Z table.
        CALL METHOD me->update_tables(
          EXPORTING im_lips = i_lips2
                    im_zzvesel = fp_zzvesel ).
"This is return variable to update delivery number.
        MOVE <fs_lips2>-vbeln TO ch_del_sr.

        UPDATE likp
           SET
"*{ Begin of V02
               zzcndoc = lv_zcndoc
"*} End of V02
               zzeda = lv_lfdat    "Estimated Date of Arrival
               zzedd = lv_lddat
               zzvesel = lv_zzvesel
           WHERE vbeln = <fs_lips2>-vbeln.
      ENDIF.
    ENDIF.

  ENDMETHOD.

  METHOD update_tables.

    DATA: li_item     TYPE STANDARD TABLE OF zibd_item,
          li_zbar     TYPE STANDARD TABLE OF zbarcode,
          lwa_header  TYPE zibd_header,
          lwa_item    TYPE zibd_item,
          lwa_zbar    TYPE zbarcode.
    FIELD-SYMBOLS <lfs_lips>  TYPE lips.

    CLEAR: lwa_header,
           lwa_zbar,
           lwa_item.

    LOOP AT im_lips
      ASSIGNING <lfs_lips>.

      MOVE <lfs_lips>-vgbel TO lwa_header-ebeln.
      MOVE <lfs_lips>-vgpos TO lwa_header-ebelp.
      MOVE <lfs_lips>-vbeln TO lwa_header-vbeln.
      READ TABLE i_ekko
        ASSIGNING <fs_ekko>
        WITH KEY ebeln = lwa_header-ebeln
      BINARY SEARCH.
      IF sy-subrc EQ 0.
        MOVE <fs_ekko>-lifnr TO lwa_header-lifnr.
        MOVE <fs_ekko>-lifnr TO lwa_item-lifnr.
      ENDIF.
      READ TABLE i_po_details
        ASSIGNING <fs_po_details>
        WITH KEY ebeln = lwa_header-ebeln
                 ebelp = lwa_header-ebelp.
      IF sy-subrc EQ 0.
        MOVE <fs_po_details>-lgort TO lwa_item-lgort.
        MOVE <fs_po_details>-werks TO lwa_item-werks.
      ENDIF.

      MOVE <lfs_lips>-vbeln TO lwa_item-vbeln.
      MOVE <lfs_lips>-posnr TO lwa_item-posnr.
      MOVE <lfs_lips>-matnr TO lwa_item-matnr.
      MOVE <lfs_lips>-lfimg TO lwa_item-lfimg.
      MOVE <lfs_lips>-meins TO lwa_item-meins.
"For Batch number we are using LOOP.
"Ideally this loop should run only once
"Get details from coil data and new batch number.
      LOOP AT i_coildata
        ASSIGNING <fs_coildata>
        WHERE ebeln = lwa_header-ebeln
          AND ebelp = lwa_header-ebelp
          AND zzvesel = im_zzvesel.
        IF <fs_coildata>-batch_consumed EQ c_x.
          CONTINUE.
        ELSE.
          MOVE <fs_coildata>-atwrt TO lwa_item-atwrt.
          MOVE <fs_coildata>-ctype TO lwa_item-ctype.
          MOVE <fs_coildata>-lichn TO lwa_item-lichn.
          MOVE <fs_coildata>-zzvesel TO lwa_item-zzvesel.
          MOVE <fs_coildata>-lifn2 TO lwa_item-mfg_lifnr.
*          MOVE <fs_coildata>-zzvesel TO lwa_zbar-zzvesel.
          MOVE <fs_coildata>-charg TO lwa_zbar-charg.

          MOVE c_x TO <fs_coildata>-batch_consumed.
          EXIT.
        ENDIF.
      ENDLOOP.
      APPEND lwa_item TO li_item.
      APPEND lwa_zbar TO li_zbar.
    ENDLOOP.

    IF lwa_header IS NOT INITIAL.
    MODIFY zibd_header
      FROM @lwa_header.
    ENDIF.
    IF li_item IS NOT INITIAL.
    MODIFY zibd_item
      FROM TABLE @li_item.
    ENDIF.
    IF li_zbar IS NOT INITIAL.
    MODIFY zbarcode
      FROM TABLE @li_zbar.
    ENDIF.
  ENDMETHOD.

  METHOD generate_batch_no.
    DATA: lv_id       TYPE qslwbez,
          lwa_tnro    TYPE tnro,
          lwa_nriv    TYPE nriv,
          lwa_nrobj   TYPE nrobj.
    IF im_ctyp EQ 'A'.
      lwa_nrobj = 'ZSCOIL_LR'.
      lv_id = 'Z22'.
    ELSEIF im_ctyp EQ 'Z' .
      lwa_nrobj = 'ZHCOIL_LR'.
      lv_id = 'Z23'.
    ENDIF.
    SELECT SINGLE *
      INTO lwa_tnro
      FROM tnro
     WHERE object = lwa_nrobj.
    IF sy-subrc EQ 0.

    ENDIF.
    lwa_nriv-object    = lwa_nrobj.

    IF lwa_tnro-dtelsobj = 'QSLWBEZ'.
      lwa_nriv-subobject = lv_id.
    ENDIF.

    lwa_nriv-nrrangenr = '01'.
    CLEAR lwa_nriv-nrlevel.

    CALL FUNCTION 'GENERATE_BATCH_NO'
      CHANGING
        nriv             = lwa_nriv
        tnro             = lwa_tnro
      EXCEPTIONS
        object_not_found = 1
        no_new_number    = 2
        OTHERS           = 3.
    IF sy-subrc <> 0.
      MESSAGE ID sy-msgid TYPE 'E' NUMBER sy-msgno
              WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
      EXIT.
    ELSEIF sy-subrc EQ 0.
      ch_number = lwa_nriv-nrlevel.
      MODIFY nriv
        FROM @lwa_nriv.
    ENDIF.
  ENDMETHOD.

