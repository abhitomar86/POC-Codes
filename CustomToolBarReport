  METHOD process_poitem_lips.

    DATA: lwa_temp TYPE lfimg ,
          lwa_cnt  TYPE i.

    IF i_file IS NOT INITIAL.
      SELECT vgbel
             vgpos
             lfimg
             vbeln
             posnr
             meins
             vrkme
        INTO TABLE i_lips
        FROM lips
         FOR ALL ENTRIES IN i_file
       WHERE vgbel = i_file-ebeln. "Line item is not given as input as
      "ebelp and vgpos datatype dont match.
      IF sy-subrc EQ 0.
        SORT i_lips
          BY vgbel
             vgpos.
      ENDIF.
      CLEAR:  wa_delv_det,
              lwa_temp,
              lwa_cnt.
"Below Loop is used Calculate the count of delivery and sum of weight
      LOOP AT i_lips
        ASSIGNING <fs_lips>.
        MOVE <fs_lips>-vgbel TO wa_delv_det-ebeln.
        MOVE <fs_lips>-vgpos TO wa_delv_det-ebelp.
        lwa_temp = lwa_temp + <fs_lips>-lfimg.
        lwa_cnt  = lwa_cnt + 1.
        AT END OF vgpos.
          MOVE lwa_temp       TO wa_delv_det-lfimg.
          MOVE lwa_cnt        TO wa_delv_det-dcnt.
          APPEND wa_delv_det TO i_delv_det.
          CLEAR: wa_delv_det,
                 lwa_temp,
                 lwa_cnt.
        ENDAT.
      ENDLOOP.
    ENDIF.
  ENDMETHOD.

  METHOD process_poitem_mseg.

    DATA: lwa_temp TYPE lfimg ,
          lwa_cnt  TYPE i.

    IF i_lips IS NOT INITIAL.
      SELECT ebeln
             ebelp
             mblnr
             mjahr
             zeile
             erfmg
             bwart
             shkzg
        FROM mseg
        INTO TABLE i_mseg
         FOR ALL ENTRIES IN i_lips
       WHERE vbeln_im = i_lips-vbeln
         AND vbelp_im = i_lips-posnr.
      IF sy-subrc EQ 0.
        SORT i_mseg
          BY ebeln
             ebelp.
      ENDIF.
      CLEAR:  wa_grn_det,
              lwa_temp,
              lwa_cnt.
"Below Loop is used Calculate the count of GRN and sum of weight
      LOOP AT i_mseg
        ASSIGNING <fs_mseg>.
        MOVE <fs_mseg>-ebeln TO wa_grn_det-ebeln.
        MOVE <fs_mseg>-ebelp TO wa_grn_det-ebelp.

        IF <fs_mseg>-shkzg EQ 'S'.
          lwa_temp = lwa_temp + <fs_mseg>-erfmg.
          lwa_cnt  = lwa_cnt + 1.
        ELSEIF <fs_mseg>-shkzg EQ 'H'.
          lwa_temp = lwa_temp - <fs_mseg>-erfmg.
          lwa_cnt  = lwa_cnt - 1.
        ENDIF.

        AT END OF ebelp.
          MOVE lwa_temp        TO wa_grn_det-erfmg.
          MOVE lwa_cnt         TO wa_grn_det-dcnt.
          APPEND wa_grn_det TO i_grn_det.
          CLEAR: wa_grn_det,
                 lwa_temp,
                 lwa_cnt.
        ENDAT.
      ENDLOOP.
    ENDIF.

  ENDMETHOD.
  METHOD process_coildata.

    DATA: lwa_temp TYPE lfimg ,
          lwa_cnt  TYPE i.
    DATA: lwa_up   TYPE lfimg ,
          lv_number   TYPE nrlevel,
          lv_charg(5) TYPE n,
          lwa_upcnt TYPE i.
    CLEAR i_up_det.
"*} End of V01  -
"*{ Begin of V02
    DATA: lv_delcnt TYPE i.

    CLEAR lv_delcnt.
"*} End of V02
      CLEAR:  wa_delv_det,
              lwa_temp,
              lwa_cnt,
              i_coil_det.
"Below Loop is used Calculate the count of input Qty and sum of weight
      LOOP AT i_coildata
        ASSIGNING <fs_coildata>.
"*{ Begin of V02
        CLEAR wa_coildata.
************************************************************************
"We shifted the Batch Number Creation logic here
"as we have to mark all the correct rows with error if any row of the PO
"is having any error and prevent its IBD creation.
"For Eg if there are 3 rows with same PO , one of them is having err = 'X'
"due to over tolerance then mark others with error as well .
************************************************************************
        IF <fs_coildata>-errpo NE c_x.
        CLEAR lv_number.
        CALL METHOD me->generate_batch_no(
          EXPORTING im_ctyp = <fs_coildata>-ctype
          CHANGING  ch_number = lv_number ).

        MOVE lv_number TO lv_charg.
        CONCATENATE <fs_coildata>-ctype lv_charg
          INTO <fs_coildata>-charg.
        ENDIF.
        MOVE <fs_coildata> TO wa_coildata.
"*} End of V02
        MOVE <fs_coildata>-ebeln   TO wa_delv_det-ebeln.
        MOVE <fs_coildata>-ebelp   TO wa_delv_det-ebelp.
        MOVE <fs_coildata>-ebeln   TO wa_up_det-ebeln.
        MOVE <fs_coildata>-ebelp   TO wa_up_det-ebelp.
        MOVE <fs_coildata>-zzvesel TO wa_up_det-zzvesel.
*        IF <fs_coildata>-err NE c_x.   "Mark Entire PO as error.
        IF <fs_coildata>-errpo NE c_x.
          lwa_temp = lwa_temp + <fs_coildata>-lfimg.
          lwa_cnt  = lwa_cnt + 1.
"*{ Begin of V01  -
          lwa_up     = lwa_up + <fs_coildata>-lfimg.
          lwa_upcnt  = lwa_upcnt + 1.
"*} End of V01  -
        ENDIF.
"Always keep AT END OF ZZVESEL above EBELP because in ZZVESEL we are incrementing
"lv_delcnt to be used later in EBELP. If we keep EBELP at top we are first moving it
"in table and then incrementing it which is incorrect.
"*{ Begin of V01  -
        AT END OF zzvesel.
"*{ Begin of V02
*          IF wa_coildata-err NE c_x.
          IF wa_coildata-errpo NE c_x. "Mark Entire PO as error.
            lv_delcnt = lv_delcnt + 1.
          ENDIF.
"*} End of V02
          MOVE lwa_up           TO wa_up_det-lfimg.
          MOVE lwa_upcnt        TO wa_up_det-dcnt.
          APPEND wa_up_det TO i_up_det.
          CLEAR: wa_up_det,
                 lwa_up,
                 lwa_upcnt.
        ENDAT.
"*} End of V01  -
        AT END OF ebelp.
          MOVE lwa_temp       TO wa_delv_det-lfimg.
          MOVE lwa_cnt        TO wa_delv_det-dcnt.
"*{ Begin of V02
          MOVE lv_delcnt      TO wa_delv_det-delcnt.
"*} End of V02
          APPEND wa_delv_det TO i_coil_det.
          CLEAR: wa_delv_det,
                 lv_delcnt,
                 lwa_temp,
                 lwa_cnt.
        ENDAT.

      ENDLOOP.

  ENDMETHOD.
  METHOD upload_data.
    DATA: i_raw TYPE truxs_t_text_data,
          li_item_chk TYPE STANDARD TABLE OF zibd_item.
"*{ Begin of V01  -
    FIELD-SYMBOLS: <fs_itemchk>  TYPE zibd_item.
"*} End of V01  -
    IF p_lcl_f IS NOT INITIAL.
      CALL FUNCTION 'TEXT_CONVERT_XLS_TO_SAP'
        EXPORTING
          i_line_header        = c_x
          i_tab_raw_data       = i_raw
          i_filename           = p_lcl_f
        TABLES
          i_tab_converted_data = i_file
        EXCEPTIONS
          conversion_failed    = 1
          OTHERS               = 2.

      IF sy-subrc <> 0.
        MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
      ENDIF.
    ELSE.
      MESSAGE text-002 TYPE 'E'.
    ENDIF.

    IF i_file IS NOT INITIAL.
      SELECT *
        FROM zibd_item
        INTO TABLE li_item_chk
         FOR ALL ENTRIES IN i_file
        WHERE lichn EQ i_file-lichn.
      IF sy-subrc EQ 0.
"*{ Begin of V01  -
        LOOP AT i_file
           ASSIGNING <fs_file>.
          READ TABLE li_item_chk
            ASSIGNING <fs_itemchk>
            WITH KEY lichn = <fs_file>-lichn.
          IF  sy-subrc EQ 0
          AND <fs_itemchk>-status_flag NE 'D'. "Allow Deleted vendor Batch to be uploaded.
            MESSAGE e000(zw) WITH text-052 <fs_file>-lichn.
            EXIT.
          ENDIF.
        ENDLOOP.
*          MESSAGE text-052 TYPE 'E'."*{ Begin of V01  ---



      ENDIF.

    ENDIF.

    SORT i_file
      BY ebeln
         ebelp.
    CLEAR wa_file_det.
"Copy the file to desired format
    LOOP AT i_file
      ASSIGNING <fs_file>.
      MOVE-CORRESPONDING <fs_file> TO wa_file_det.
      APPEND wa_file_det TO i_file_det.
      CLEAR wa_file_det.
    ENDLOOP.

    IF i_file IS NOT INITIAL.
      "Get Data from EKPO Purchasing Document Item
      SELECT ebeln
             ebelp
             txz01
             werks
             lgort
             menge
             uebto
             uebtk
             bwtar
        FROM ekpo
        INTO TABLE i_po_details
        FOR ALL ENTRIES IN i_file
       WHERE ebeln = i_file-ebeln
         AND ebelp = i_file-ebelp.
      IF sy-subrc EQ 0.
        SORT i_po_details
          BY ebeln
             ebelp.
      ENDIF.
      "Get Data from EKKN Account Assignment Table
      SELECT ebeln
             ebelp
             vbeln
        FROM ekkn
        INTO TABLE i_ekkn
         FOR ALL ENTRIES IN i_file
       WHERE ebeln EQ i_file-ebeln
         AND ebelp EQ i_file-ebelp.
      IF sy-subrc EQ 0.
        SORT i_ekkn
          BY ebeln
             ebelp.
        "Get Data from VBAK Sales Document: Header Data
        SELECT vbeln
               kunnr
          FROM vbak
          INTO TABLE i_vbak
           FOR ALL ENTRIES IN i_ekkn
         WHERE vbeln EQ i_ekkn-vbeln.
        IF sy-subrc EQ 0.
          SORT i_vbak
            BY vbeln.
          "Get Data from KNA1 - Customer Master Data
          SELECT kunnr
                 name1
            FROM kna1
            INTO TABLE i_kna1
             FOR ALL ENTRIES IN i_vbak
           WHERE kunnr EQ i_vbak-kunnr.
          IF sy-subrc EQ 0.
            SORT i_kna1
              BY kunnr.
          ENDIF.
        ENDIF.
      ENDIF.
      "Get Data from EKKO Purchasing Document Header
      SELECT ebeln
             lifnr
             frgke
        FROM ekko
        INTO TABLE i_ekko
         FOR ALL ENTRIES IN i_file
       WHERE ebeln = i_file-ebeln.
      IF sy-subrc EQ 0.
        SORT i_ekko
          BY ebeln.
        "Get Data from EKPA Partner Roles Table
        SELECT ebeln
               parvw
               lifn2
          FROM ekpa
          INTO TABLE i_ekpa
           FOR ALL ENTRIES IN i_ekko
         WHERE ebeln EQ i_ekko-ebeln
           AND ( parvw EQ 'MN' OR
               parvw EQ 'HS') .
        IF sy-subrc EQ 0.
          SORT i_ekpa
            BY ebeln.
          "Get Data from LFA1 - Vendor Master Table
          SELECT lifnr
                 name1
            FROM lfa1
            INTO TABLE i_lfa1
             FOR ALL ENTRIES IN i_ekpa
           WHERE lifnr EQ i_ekpa-lifn2.
          IF sy-subrc EQ 0.
            SORT i_lfa1
              BY lifnr.
          ENDIF.

        ENDIF.
        ""Append Data from LFA1 - Vendor Master Table
        SELECT lifnr
               name1
          FROM lfa1
          APPENDING TABLE i_lfa1
           FOR ALL ENTRIES IN i_ekko
         WHERE lifnr EQ i_ekko-lifnr.
        IF sy-subrc EQ 0.
          SORT i_lfa1
            BY lifnr.
        ENDIF.
      ENDIF.
    ENDIF.  "if file is not initial.

    CALL METHOD me->process_poitem_lips.

    CALL METHOD me->process_poitem_mseg.

  ENDMETHOD.

  METHOD process_data.

    DATA: lv_srno     TYPE i,
          lv_number   TYPE nrlevel,
          lv_qty_chk  TYPE lfimg,
          lv_charg(5) TYPE n.
    CLEAR: wa_posummary,
           wa_delvsumm,
           lv_qty_chk,
           wa_coildata,
           lv_srno.
    UNASSIGN <fs_file>.
    LOOP AT i_file
      ASSIGNING <fs_file>.
"-------------------PO Summary Data-----------------------------------*
      "PO Vendor Name
      READ TABLE i_ekko
        ASSIGNING <fs_ekko>
        WITH KEY ebeln = <fs_file>-ebeln
        BINARY SEARCH.
      IF sy-subrc EQ 0.
        IF ( <fs_ekko>-frgke NE 'A'
        AND <fs_ekko>-frgke NE 'R').
            wa_coildata-err = c_x.
            wa_coildata-msg = 'PO Not in Released Status'(050).
        ENDIF.
        READ TABLE i_lfa1
          ASSIGNING <fs_lfa1>
          WITH KEY lifnr = <fs_ekko>-lifnr
          BINARY SEARCH.
        IF sy-subrc EQ 0.
          MOVE <fs_lfa1>-name1 TO wa_posummary-poname1.
        ENDIF.
      ELSE.
"PO Doesnt Exits , Check Next Record.
        CONTINUE.
      ENDIF.
      "PO Number
      MOVE <fs_file>-ebeln TO wa_posummary-ebeln.
      "PO Line Item
      MOVE <fs_file>-ebelp TO wa_posummary-ebelp.
      "Vessel Number
      MOVE <fs_file>-zzvesel TO wa_posummary-zzvesel.

      UNASSIGN <fs_po_details>.
      READ TABLE i_po_details
        ASSIGNING <fs_po_details>
        WITH KEY ebeln = <fs_file>-ebeln
                 ebelp = <fs_file>-ebelp
      BINARY SEARCH.
      IF sy-subrc EQ 0.
        "PO Item Description
        MOVE <fs_po_details>-txz01 TO wa_posummary-txz01.
        "Storage Location
        MOVE <fs_po_details>-lgort TO wa_posummary-lgort.
        "PO Qty
        MOVE <fs_po_details>-menge TO wa_posummary-menge.
        MOVE <fs_po_details>-bwtar TO wa_coildata-bwtar.

        IF  <fs_po_details>-uebtk IS INITIAL
*        AND <fs_po_details>-uebto NE '0.0'
        AND <fs_po_details>-tol_det NE c_x.
"Calculate Tolerance Quantity.
          <fs_po_details>-tol_qty = <fs_po_details>-menge +
                                    ( <fs_po_details>-menge *
                                      <fs_po_details>-uebto / 100 ).
"Set below indicator. This indicator is set when tolerance limit
"is determined. This is because we dont want to determine tolerance
"limit as we will be subtracting delivered quantity from tolerance
"limit to create new tolerance value. If this indicator is not set
"we keep resetting tolerance limit.
          <fs_po_details>-tol_det = c_x.
        ENDIF.

        READ TABLE i_delv_det
          ASSIGNING <fs_delv>
          WITH KEY ebeln = <fs_file>-ebeln
                   ebelp = <fs_file>-ebelp.
        IF sy-subrc EQ 0.
          "Inbound Quantity
          MOVE <fs_delv>-lfimg TO wa_posummary-lfimg.
          "Inbound QTY EA
          MOVE <fs_delv>-dcnt TO wa_posummary-in_qty_ea.
          IF  <fs_po_details>-uebtk IS INITIAL.
*          AND <fs_po_details>-uebto NE '0.0'.
"Formula for checking error.
"If (Current Qty + Delivered Qty) <= Tolerance Qty
"if true then tolerance Qty = tolerance Qty - Current Qty
"Else Error
            CLEAR lv_qty_chk.

            lv_qty_chk = <fs_file>-lfimg + <fs_delv>-lfimg.

            IF lv_qty_chk LE <fs_po_details>-tol_qty.
              <fs_po_details>-tol_qty = <fs_po_details>-tol_qty
                                      - <fs_file>-lfimg.
"This is because delivery quantity is always subracted
            ELSE.
              wa_coildata-err = c_x.
              wa_coildata-msg = 'Quantity greater than Tolerance limit'(051).
            ENDIF.
          ENDIF.
"*{ Begin of V02
        ELSE. " READ TABLE i_delv_det
"Case: When there is a fresh PO (whit no delivery) trying to create a IBD
"with more than Tolerance Limit.
          IF  <fs_po_details>-uebtk IS INITIAL.
"Formula for checking error.
"If (Current Qty + Delivered Qty) <= Tolerance Qty
"if true then tolerance Qty = tolerance Qty - Current Qty
"Else Error
            CLEAR lv_qty_chk.
"Here the Delivery Quantity is zero. We check the Upload Quantity only.
            lv_qty_chk = <fs_file>-lfimg.

            IF lv_qty_chk LE <fs_po_details>-tol_qty.
              <fs_po_details>-tol_qty = <fs_po_details>-tol_qty
                                      - <fs_file>-lfimg.
"This is because delivery quantity is always subracted
            ELSE.
              wa_coildata-err = c_x.
              wa_coildata-msg = 'Quantity greater than Tolerance limit'(051).
            ENDIF.
          ENDIF.
"*} End of V02
        ENDIF.
      ENDIF.

      READ TABLE i_grn_det
        ASSIGNING <fs_grn>
        WITH KEY ebeln = <fs_file>-ebeln
                 ebelp = <fs_file>-ebelp.
      IF sy-subrc EQ 0.
        "Inbound Quantity
        MOVE <fs_grn>-erfmg  TO wa_posummary-erfmg.
        "Inbound QTY EA
        MOVE <fs_grn>-dcnt TO wa_posummary-grn_ea.
      ENDIF.

      "Customer Name
      UNASSIGN <fs_ekkn>.
      READ TABLE i_ekkn
        ASSIGNING <fs_ekkn>
        WITH KEY ebeln = <fs_file>-ebeln
                 ebelp = <fs_file>-ebelp
      BINARY SEARCH.
      IF sy-subrc EQ 0.
        READ TABLE i_vbak
          ASSIGNING <fs_vbak>
          WITH KEY vbeln = <fs_ekkn>-vbeln
          BINARY SEARCH.
        IF sy-subrc EQ 0.
          READ TABLE i_kna1
            ASSIGNING <fs_kna1>
            WITH KEY kunnr = <fs_vbak>-kunnr
            BINARY SEARCH.
          IF sy-subrc EQ 0.
            MOVE <fs_kna1>-name1 TO wa_posummary-cust_name.
          ENDIF.
        ENDIF.
      ENDIF.

      "Mfg Vendor Name
      READ TABLE i_ekpa
        ASSIGNING <fs_ekpa>
        WITH KEY ebeln = <fs_file>-ebeln
      BINARY SEARCH.
      IF sy-subrc EQ 0.
        MOVE <fs_ekpa>-lifn2 TO wa_posummary-lifn2.
        READ TABLE i_lfa1
          ASSIGNING <fs_lfa1>
          WITH KEY lifnr = <fs_ekpa>-lifn2
          BINARY SEARCH.
        IF sy-subrc EQ 0.
          MOVE <fs_lfa1>-name1 TO wa_posummary-mfgname1.
        ENDIF.
      ENDIF.

      APPEND wa_posummary TO i_posummary.
   "-------------------End of PO Summary Data--------------------------*

   "-------------------Coil Data---------------------------------------*
      " Copy Coil Data
      lv_srno = lv_srno + 1.
      MOVE lv_srno             TO wa_coildata-del_sr.
      MOVE <fs_file>-lichn     TO wa_coildata-lichn.
      MOVE <fs_file>-atwrt     TO wa_coildata-atwrt.
      MOVE <fs_file>-lfimg     TO wa_coildata-lfimg.
      MOVE <fs_file>-vrkme     TO wa_coildata-vrkme.
      MOVE <fs_file>-zzvesel   TO wa_coildata-zzvesel.
      MOVE <fs_file>-ebeln     TO wa_coildata-ebeln.
      MOVE <fs_file>-ebelp     TO wa_coildata-ebelp.
      MOVE wa_posummary-txz01  TO wa_coildata-txz01.
      MOVE wa_posummary-lgort  TO wa_coildata-lgort.
      MOVE <fs_file>-lddat     TO wa_coildata-lddat.
      MOVE <fs_file>-lfdat     TO wa_coildata-lfdat.
      MOVE <fs_file>-ctype     TO wa_coildata-ctype.
      MOVE wa_posummary-cust_name  TO wa_coildata-cust_name.
      MOVE wa_posummary-lifn2      TO wa_coildata-lifn2.
      MOVE wa_posummary-mfgname1   TO wa_coildata-mfgname1.
      MOVE wa_posummary-poname1    TO wa_coildata-poname1.
"*{ Begin of V02
      MOVE <fs_file>-zzcndoc   TO wa_coildata-zzcndoc.
"*} End of V02
"We Calculate the Batch number here to assign it later to delivery and
"Z table.
************************************************************************
"We shifted the Batch Number Creation logic to another loop at i_coildata
"as we have to mark all the correct rows with error if any row of the PO
"is having any error and prevent its IBD creation.
"For Eg if there are 3 rows with same PO , one of them is having err = 'X'
"due to over tolerance then mark others with error as well .
************************************************************************
**      IF wa_coildata-err NE c_x.
**      CALL METHOD me->generate_batch_no(
**        EXPORTING im_ctyp = wa_coildata-ctype
**        CHANGING  ch_number = lv_number ).
**
**      MOVE lv_number TO lv_charg.
**      CONCATENATE wa_coildata-ctype lv_charg
**        INTO wa_coildata-charg.
**      ENDIF.
***********************************************************************
      APPEND wa_coildata TO i_coildata.

      CLEAR wa_coildata.
      CLEAR wa_posummary.
  "-------------------End of Coil Data---------------------------------*
    ENDLOOP.

    LOOP AT i_coildata
      ASSIGNING <fs_coildata>.
***********************************************************************
      IF <fs_coildata>-err EQ c_x.
        MOVE c_x to wa_coildata-errpo.
        MODIFY i_coildata
          FROM wa_coildata
          TRANSPORTING errpo
          WHERE ebeln = <fs_coildata>-ebeln.
      ENDIF.
***********************************************************************
    ENDLOOP.
"*{ Begin of V01  -
    SORT i_coildata
      BY ebeln
         ebelp
         zzvesel.
"*} End of V01  -
    CLEAR: wa_posummary,
           wa_delvsumm,
           wa_coildata,
           lv_srno.

    SORT i_posummary
      BY ebeln
         ebelp
         zzvesel.    "*{ Begin of V01  -
    DELETE ADJACENT DUPLICATES FROM i_posummary
      COMPARING ebeln
                ebelp
                zzvesel.  "*{ Begin of V01  -
    CALL METHOD me->process_coildata.
    LOOP AT i_posummary
      ASSIGNING <fs_posummary>.
      CLEAR: wa_delvsumm,
             wa_posummary.
   "-------------------Delivery Summary -------------------------------*
      " Copy Delivery Summary Data
      lv_srno = lv_srno + 1.
      MOVE lv_srno                   TO wa_delvsumm-del_sr.
"*{ Begin of V01  -
      READ TABLE i_up_det
        ASSIGNING <fs_up>
        WITH KEY ebeln = <fs_posummary>-ebeln
                 ebelp = <fs_posummary>-ebelp
                 zzvesel = <fs_posummary>-zzvesel.
      IF sy-subrc EQ 0.
        MOVE <fs_up>-lfimg  TO wa_delvsumm-lfimg.
        MOVE <fs_up>-dcnt   TO wa_delvsumm-no_of_coils.
      ENDIF.
"*} End of V01  -
      READ TABLE i_coil_det
        ASSIGNING <fs_delv>
        WITH KEY ebeln = <fs_posummary>-ebeln
                 ebelp = <fs_posummary>-ebelp.
      IF sy-subrc EQ 0.
        MOVE <fs_delv>-lfimg TO <fs_posummary>-up_qty.
        MOVE <fs_delv>-dcnt  TO <fs_posummary>-up_ea.
"*{ Begin of V02
*        MOVE <fs_delv>-dcnt  TO <fs_posummary>-del_no. --
        MOVE <fs_delv>-delcnt  TO <fs_posummary>-del_no. "++

"*} End of V02
      ENDIF.
"*{ Begin of V01  -
*      MOVE <fs_posummary>-up_qty     TO wa_delvsumm-lfimg.
*      MOVE <fs_posummary>-up_ea      TO wa_delvsumm-no_of_coils.
"*} End of V01  -
      MOVE <fs_posummary>-txz01      TO wa_delvsumm-txz01.
      MOVE <fs_posummary>-zzvesel    TO wa_delvsumm-zzvesel.
      MOVE <fs_posummary>-ebeln      TO wa_delvsumm-ebeln.
      MOVE <fs_posummary>-ebelp      TO wa_delvsumm-ebelp.
      MOVE <fs_posummary>-txz01      TO wa_delvsumm-txz01.
      MOVE <fs_posummary>-cust_name  TO wa_delvsumm-cust_name.
      MOVE <fs_posummary>-mfgname1   TO wa_delvsumm-mfgname1.
      MOVE <fs_posummary>-poname1    TO wa_delvsumm-poname1.
      APPEND wa_delvsumm TO i_delvsumm.
   "-------------------End of Delivery Summary-------------------------*
      MOVE <fs_posummary> TO wa_posummary.

      AT END OF ebelp.

      ENDAT.

    ENDLOOP.

    CLEAR lv_srno.

    LOOP AT i_coildata
      ASSIGNING <fs_coildata>.

      READ TABLE i_delvsumm
        ASSIGNING <fs_delvsumm>
        WITH KEY ebeln = <fs_coildata>-ebeln
                 ebelp = <fs_coildata>-ebelp
                 zzvesel = <fs_coildata>-zzvesel.
      IF sy-subrc EQ 0.
        MOVE <fs_delvsumm>-del_sr TO <fs_coildata>-del_sr.
      ENDIF.

    ENDLOOP.
"*{ Begin of V01  -
    SORT i_posummary
      BY ebeln
         ebelp.
    DELETE ADJACENT DUPLICATES FROM i_posummary
      COMPARING ebeln
                ebelp.
    SORT i_delvsumm
      BY ebeln
         ebelp
         zzvesel.
"*} End of V01  -
    CLEAR: lv_srno,
           wa_delvsumm.

  ENDMETHOD.

